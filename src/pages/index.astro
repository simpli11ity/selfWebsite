---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TechStack from '../components/TechStack.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<div class="page-shell">
			<Header />
			<main>
				<section class="hero">
					<div class="hero-bg"></div>
					<div class="hero-overlay"></div>

					<div class="hero-inner">
						<p class="eyebrow">DevOps • Cloud • Travel</p>
						<h1>Building Reliable Systems. Exploring the World.</h1>
						<p class="lead">
							I’m Peter Swayne, a DevOps engineer focused on automation, infrastructure,
							and practical systems work, with travel notes and project write-ups alongside it.
						</p>

						<div class="hero-actions">
					<a class="btn btn-secondary" href="/projects/">View Projects</a>
				</div>
			</div>
		</section>
				<section class="content-section">
					<div class="section-heading">
						<div>
							<p class="section-label">Explore</p>
							<h2>What’s here</h2>
						</div>
					</div>

					<div class="card-grid">
						<article class="content-card">
							<span class="tag">Travel</span>
							<h3>Travel</h3>
							<p>
								Trips, photos, routes, just casual memories and things experienced.
							</p>
							<a class="text-link" href="/travel/">Explore travel →</a>
						</article>

						<article class="content-card">
							<span class="tag">Projects</span>
							<h3>Projects</h3>
							<p>
								Automation, infrastructure, small builds, experiments, and proper write-ups.
							</p>
							<a class="text-link" href="/projects/">View projects →</a>
						</article>

					</div>
				</section>

				<section class="content-section lower-grid">
					<article class="info-panel">
						<p class="section-label">Now</p>
						<h2>Current focus</h2>
						<ul>
							<li>Cleaning up the travel archive so posts feel consistent.</li>
							<li>Publishing better project write-ups instead of half-finished notes.</li>
							<li>Keeping the site dark, simple, fast, and easy to maintain, simplicity is key.</li>
						</ul>
					</article>

					<article class="info-panel">
						<p class="section-label">What to expect</p>
						<h2>Style of the site</h2>
						<ul>
							<li>Short posts.</li>
							<li>Photos with context.</li>
							<li>Projects with actual detail: what I built, what broke, what changed.</li>
						</ul>
					</article>
				</section>

				<TechStack />
			</main>
			<Footer />
		</div>
	</body>
</html>
