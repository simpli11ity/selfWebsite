---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';

const posts = (await getCollection('travel')).sort(
	(a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: min(1200px, calc(100% - 2rem));
				margin: 0 auto;
			}
			.travel-hero {
				margin-bottom: 3rem;
				position: relative;
				height: 320px;
				border-radius: 12px;
				overflow: hidden;
				display: flex;
				align-items: center;
				justify-content: center;
				background: linear-gradient(135deg, rgba(77, 163, 255, 0.15), rgba(147, 197, 253, 0.1));
				border: 1px solid rgba(147, 197, 253, 0.2);
			}
			.travel-hero-content {
				text-align: center;
				z-index: 2;
				position: relative;
			}
			.travel-hero-emoji {
				font-size: 5rem;
				margin-bottom: 1rem;
				display: block;
			}
			.travel-hero h2 {
				font-size: 2.5rem;
				margin: 0;
				color: var(--text);
				letter-spacing: -0.02em;
			}
			.posts-list {
				display: flex;
				flex-direction: column;
				gap: 2rem;
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.post-item {
				display: block;
			}
			.post-item a {
				display: block;
				text-decoration: none;
				cursor: pointer;
			}
			.post-item:nth-child(even) {
				direction: ltr;
			}
			.post-image {
				position: relative;
				overflow: hidden;
				border-radius: 12px;
				height: 320px;
				display: flex;
				align-items: flex-end;
			}
			.post-image img {
				position: absolute;
				width: 100%;
				height: 100%;
				object-fit: cover;
				display: block;
				z-index: 0;
			}
			.post-image::after {
				content: '';
				position: absolute;
				inset: 0;
				background: linear-gradient(to top, rgba(0, 0, 0, 0.6), transparent);
				z-index: 1;
			}
			.post-image-text {
				position: relative;
				z-index: 2;
				padding: 2rem;
				width: 100%;
			}
			.post-image .title {
				font-size: 1.75rem;
				margin: 0 0 0.5rem;
				color: white;
				line-height: 1.2;
			}
			.post-image .date {
				margin: 0;
				color: rgba(255, 255, 255, 0.9);
				font-size: 0.95rem;
			}
			.post-item a:hover .title,
			.post-item a:hover .date {
				color: rgb(var(--accent));
			}
			@media (max-width: 768px) {
				main {
					width: calc(100% - 1rem);
				}
				.travel-hero {
					height: 240px;
				}
				.travel-hero-emoji {
					font-size: 3rem;
				}
				.travel-hero h2 {
					font-size: 1.8rem;
				}
				.post-item {
					grid-template-columns: 1fr;
					gap: 1rem;
				}
				.post-item:nth-child(even) {
					direction: ltr;
				}
				.post-content .title {
					font-size: 1.35rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section>
				<div class="travel-hero">
					<div class="travel-hero-content">
						<span class="travel-hero-emoji">🌍</span>
						<h2>Let's Travel</h2>
					</div>
				</div>
				<ul class="posts-list">
					{
						posts.map((post) => (
							<li class="post-item">
								<a href={`/travel/${post.slug}/`}>
									<div class="post-image">
										<img width={500} height={350} src={post.data.heroImage} alt="" />
										<div class="post-image-text">
											<h3 class="title">{post.data.title}</h3>
											<p class="date">
												<FormattedDate date={post.data.pubDate} />
											</p>
										</div>
									</div>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
