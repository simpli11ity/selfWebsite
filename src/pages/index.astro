---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<div class="page-shell">
			<Header />
			<main>
				<section class="hero">
					<div class="hero-bg"></div>
					<div class="hero-overlay"></div>

					<div class="hero-inner">
						<p class="eyebrow">DevOps • Cloud • Travel</p>
						<h1>Building Reliable Systems. Exploring the World.</h1>
						<p class="lead">
							I’m Peter Swayne — a DevOps engineer focused on automation, infrastructure,
							and practical systems work, with travel notes and project write-ups alongside it.
						</p>

						<div class="hero-actions">
							<a class="btn btn-primary" href="/about/">About Me</a>
							<a class="btn btn-secondary" href="/projects/">View Projects</a>
						</div>
					</div>
				</section>

				<section class="about-preview section-card">
					<div class="about-image">
						<img src="/images/about/me.jpg" alt="Peter Swayne" />
					</div>

					<div class="about-copy">
						<p class="section-label">About Me</p>
						<h2>Engineer by profession. Explorer by habit.</h2>
						<p>
							I work across cloud, automation, CI/CD, infrastructure, and reliability.
							This site is a mix of technical write-ups, travel posts, and useful things
							worth keeping in one place.
						</p>
						<p>
							I prefer practical work over fluff: systems that deploy cleanly, projects with
							actual outcomes, and travel notes that are worth reading again later.
						</p>

						<div class="feature-grid">
							<div class="feature">
								<h3>DevOps & Cloud</h3>
								<p>AWS, Terraform, Docker, Kubernetes, CI/CD</p>
							</div>
							<div class="feature">
								<h3>Automation</h3>
								<p>Scripting, infrastructure workflows, small tools</p>
							</div>
							<div class="feature">
								<h3>Reliability</h3>
								<p>Monitoring, logging, deployment quality, ops</p>
							</div>
							<div class="feature">
								<h3>Travel</h3>
								<p>Trips, routes, photos, and what was actually worth doing</p>
							</div>
						</div>
					</div>
				</section>

				<section class="content-section">
					<div class="section-heading">
						<div>
							<p class="section-label">Explore</p>
							<h2>What’s here</h2>
						</div>
					</div>

					<div class="card-grid">
						<article class="content-card">
							<span class="tag">Travel</span>
							<h3>Travel</h3>
							<p>
								Trips, photos, routes, and notes that are actually useful once the trip is over.
							</p>
							<a class="text-link" href="/travel/">Explore travel →</a>
						</article>

						<article class="content-card">
							<span class="tag">Projects</span>
							<h3>Projects</h3>
							<p>
								Automation, infrastructure, small builds, experiments, and proper write-ups.
							</p>
							<a class="text-link" href="/projects/">View projects →</a>
						</article>

						<article class="content-card">
							<span class="tag">About</span>
							<h3>About</h3>
							<p>
								What I do, what I focus on, and what this site is trying to be.
							</p>
							<a class="text-link" href="/about/">Read more →</a>
						</article>
					</div>
				</section>

				<section class="content-section lower-grid">
					<article class="info-panel">
						<p class="section-label">Now</p>
						<h2>Current focus</h2>
						<ul>
							<li>Cleaning up the travel archive so posts feel consistent.</li>
							<li>Publishing better project write-ups instead of half-finished notes.</li>
							<li>Keeping the site dark, simple, fast, and easy to maintain.</li>
						</ul>
					</article>

					<article class="info-panel">
						<p class="section-label">What to expect</p>
						<h2>Style of the site</h2>
						<ul>
							<li>Short posts over bloated essays.</li>
							<li>Photos with context, not just image dumps.</li>
							<li>Projects with actual detail: what I built, what broke, what changed.</li>
						</ul>
					</article>
				</section>
			</main>
			<Footer />
		</div>
	</body>
</html>

<style>
:root {
	--bg: #0f1318;
	--bg-soft: #171c23;
	--panel: rgba(22, 28, 36, 0.82);
	--panel-border: rgba(255, 255, 255, 0.06);
	--text: #f3f1ec;
	--muted: #a9b0b8;
	--accent: #a97b5b;
	--accent-2: #d7b08f;
	--shadow: 0 20px 60px rgba(0, 0, 0, 0.38);
	--radius: 24px;
}

html, body {
	margin: 0;
	padding: 0;
	background:
		radial-gradient(circle at top left, rgba(169,123,91,0.08), transparent 26%),
		radial-gradient(circle at top right, rgba(255,255,255,0.025), transparent 18%),
		linear-gradient(180deg, #0d1116 0%, #13181f 100%);
	color: var(--text);
	font-family: Inter, system-ui, sans-serif;
}

main {
	width: min(1180px, calc(100% - 2rem));
	margin: 0 auto;
	padding: 1.25rem 0 4rem;
}

.hero {
	position: relative;
	min-height: 560px;
	border-radius: 30px;
	overflow: hidden;
	display: flex;
	align-items: center;
	padding: 4rem;
	margin-bottom: 2rem;
	background: linear-gradient(90deg, rgba(11,14,18,0.94), rgba(11,14,18,0.56));
}

.hero-bg {
	position: absolute;
	inset: 0;
	background:
		linear-gradient(90deg, rgba(10,13,18,0.74), rgba(10,13,18,0.18)),
		url('/images/home/hero.jpg') center / cover no-repeat;
	filter: saturate(0.75) brightness(0.7);
}

.hero-overlay {
	position: absolute;
	inset: 0;
	background:
		radial-gradient(circle at 70% 30%, rgba(169,123,91,0.1), transparent),
		radial-gradient(circle at 70% 60%, rgba(255,255,255,0.04), transparent);
}

.eyebrow, .section-label {
	color: var(--accent-2);
}

.btn-primary {
	background: linear-gradient(135deg, #b68460, #8d6247);
}

.tag {
	background: rgba(169,123,91,0.12);
	color: var(--accent-2);
}
</style>