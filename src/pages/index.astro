---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<div class="page-shell">
			<Header />
			<main>
				<section class="hero">
					<div class="hero-bg"></div>
					<div class="hero-overlay"></div>

					<div class="hero-inner">
						<p class="eyebrow">DevOps • Cloud • Travel</p>
						<h1>Building Reliable Systems. Exploring the World.</h1>
						<p class="lead">
							I’m Peter Swayne — a DevOps engineer focused on automation, infrastructure,
							and practical systems work, with travel notes and project write-ups alongside it.
						</p>

						<div class="hero-actions">
							<a class="btn btn-primary" href="/about/">About Me</a>
							<a class="btn btn-secondary" href="/projects/">View Projects</a>
						</div>
					</div>
				</section>

				<section class="about-preview section-card">
					<div class="about-image">
						<img
							src="/images/about/me.jpg"
							alt="Peter Swayne"
						/>
					</div>

					<div class="about-copy">
						<p class="section-label">About Me</p>
						<h2>Engineer by profession. Explorer by habit.</h2>
						<p>
							I work across cloud, automation, CI/CD, infrastructure, and reliability.
							This site is a mix of technical write-ups, travel posts, and useful things
							worth keeping in one place.
						</p>
						<p>
							I prefer practical work over fluff: systems that deploy cleanly, projects with
							actual outcomes, and travel notes that are worth reading again later.
						</p>

						<div class="feature-grid">
							<div class="feature">
								<h3>DevOps & Cloud</h3>
								<p>AWS, Terraform, Docker, Kubernetes, CI/CD</p>
							</div>
							<div class="feature">
								<h3>Automation</h3>
								<p>Scripting, infrastructure workflows, small tools</p>
							</div>
							<div class="feature">
								<h3>Reliability</h3>
								<p>Monitoring, logging, deployment quality, ops</p>
							</div>
							<div class="feature">
								<h3>Travel</h3>
								<p>Trips, routes, photos, and what was actually worth doing</p>
							</div>
						</div>
					</div>
				</section>

				<section class="content-section">
					<div class="section-heading">
						<div>
							<p class="section-label">Explore</p>
							<h2>What’s here</h2>
						</div>
					</div>

					<div class="card-grid">
						<article class="content-card">
							<span class="tag">Travel</span>
							<h3>Travel</h3>
							<p>
								Trips, photos, routes, and notes that are actually useful once the trip is over.
							</p>
							<a class="text-link" href="/travel/">Explore travel →</a>
						</article>

						<article class="content-card">
							<span class="tag">Projects</span>
							<h3>Projects</h3>
							<p>
								Automation, infrastructure, small builds, experiments, and proper write-ups.
							</p>
							<a class="text-link" href="/projects/">View projects →</a>
						</article>

						<article class="content-card">
							<span class="tag">About</span>
							<h3>About</h3>
							<p>
								What I do, what I focus on, and what this site is trying to be.
							</p>
							<a class="text-link" href="/about/">Read more →</a>
						</article>
					</div>
				</section>

				<section class="content-section lower-grid">
					<article class="info-panel">
						<p class="section-label">Now</p>
						<h2>Current focus</h2>
						<ul>
							<li>Cleaning up the travel archive so posts feel consistent.</li>
							<li>Publishing better project write-ups instead of half-finished notes.</li>
							<li>Keeping the site dark, simple, fast, and easy to maintain.</li>
						</ul>
					</article>

					<article class="info-panel">
						<p class="section-label">What to expect</p>
						<h2>Style of the site</h2>
						<ul>
							<li>Short posts over bloated essays.</li>
							<li>Photos with context, not just image dumps.</li>
							<li>Projects with actual detail: what I built, what broke, what changed.</li>
						</ul>
					</article>
				</section>
			</main>
			<Footer />
		</div>
	</body>
</html>

<style>
	:root {
		--bg: #08111f;
		--bg-soft: #0d1728;
		--panel: rgba(14, 24, 41, 0.78);
		--panel-border: rgba(255, 255, 255, 0.08);
		--text: #eef4ff;
		--muted: #a9b7cd;
		--accent: #4da3ff;
		--accent-2: #7cc4ff;
		--shadow: 0 20px 60px rgba(0, 0, 0, 0.35);
		--radius: 24px;
	}

	html,
	body {
		margin: 0;
		padding: 0;
		background:
			radial-gradient(circle at top left, rgba(55, 116, 200, 0.16), transparent 30%),
			radial-gradient(circle at top right, rgba(72, 143, 255, 0.14), transparent 28%),
			linear-gradient(180deg, #07101c 0%, #091321 100%);
		color: var(--text);
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI',
			sans-serif;
	}

	.page-shell {
		min-height: 100vh;
	}

	main {
		width: min(1180px, calc(100% - 2rem));
		margin: 0 auto;
		padding: 1.25rem 0 4rem;
	}

	.hero {
		position: relative;
		min-height: 560px;
		border-radius: 30px;
		overflow: hidden;
		display: flex;
		align-items: center;
		padding: 4rem;
		margin-bottom: 2rem;
		background:
			linear-gradient(90deg, rgba(7, 13, 24, 0.92) 0%, rgba(7, 13, 24, 0.7) 45%, rgba(7, 13, 24, 0.3) 100%);
		box-shadow: var(--shadow);
		border: 1px solid rgba(255, 255, 255, 0.06);
	}

	.hero-bg {
		position: absolute;
		inset: 0;
		background:
			linear-gradient(90deg, rgba(5, 10, 18, 0.72), rgba(5, 10, 18, 0.18)),
			url('/images/home/hero.jpg') center center / cover no-repeat;
		transform: scale(1.02);
	}

	.hero-overlay {
		position: absolute;
		inset: 0;
		background:
			radial-gradient(circle at 75% 30%, rgba(77, 163, 255, 0.18), transparent 22%),
			radial-gradient(circle at 70% 60%, rgba(77, 163, 255, 0.1), transparent 20%);
	}

	.hero-inner {
		position: relative;
		z-index: 1;
		max-width: 640px;
	}

	.eyebrow,
	.section-label {
		margin: 0 0 0.85rem;
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--accent-2);
	}

	.hero h1 {
		margin: 0;
		font-size: clamp(2.5rem, 5vw, 4.5rem);
		line-height: 0.98;
		letter-spacing: -0.04em;
		max-width: 12ch;
	}

	.lead {
		margin: 1.3rem 0 0;
		font-size: 1.08rem;
		line-height: 1.75;
		color: var(--muted);
		max-width: 58ch;
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.9rem;
		margin-top: 2rem;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.95rem 1.3rem;
		border-radius: 999px;
		text-decoration: none;
		font-weight: 700;
		transition: 0.2s ease;
	}

	.btn-primary {
		background: linear-gradient(135deg, var(--accent), #2d7be7);
		color: white;
		box-shadow: 0 10px 30px rgba(77, 163, 255, 0.22);
	}

	.btn-primary:hover {
		transform: translateY(-1px);
	}

	.btn-secondary {
		background: rgba(255, 255, 255, 0.06);
		color: var(--text);
		border: 1px solid rgba(255, 255, 255, 0.1);
	}

	.section-card,
	.info-panel,
	.content-card {
		background: var(--panel);
		backdrop-filter: blur(12px);
		border: 1px solid var(--panel-border);
		box-shadow: var(--shadow);
	}

	.about-preview {
		display: grid;
		grid-template-columns: 420px 1fr;
		gap: 2rem;
		padding: 2rem;
		border-radius: var(--radius);
		margin-bottom: 2rem;
	}

	.about-image img {
		width: 100%;
		height: 100%;
		min-height: 420px;
		object-fit: cover;
		border-radius: 20px;
		display: block;
	}

	.about-copy h2,
	.content-section h2,
	.info-panel h2 {
		margin: 0 0 1rem;
		font-size: clamp(1.8rem, 3vw, 2.7rem);
		line-height: 1.08;
		letter-spacing: -0.03em;
	}

	.about-copy p,
	.content-card p,
	.info-panel li {
		color: var(--muted);
		line-height: 1.7;
		font-size: 1rem;
	}

	.feature-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
		margin-top: 1.6rem;
	}

	.feature {
		padding: 1rem 1.1rem;
		border-radius: 18px;
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid rgba(255, 255, 255, 0.07);
	}

	.feature h3 {
		margin: 0 0 0.45rem;
		font-size: 1rem;
	}

	.feature p {
		margin: 0;
		font-size: 0.92rem;
		color: var(--muted);
	}

	.content-section {
		margin-bottom: 2rem;
	}

	.section-heading {
		display: flex;
		align-items: end;
		justify-content: space-between;
		margin-bottom: 1rem;
	}

	.card-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1.2rem;
	}

	.content-card {
		padding: 1.5rem;
		border-radius: 22px;
	}

	.content-card h3 {
		margin: 0.7rem 0 0.75rem;
		font-size: 1.35rem;
	}

	.tag {
		display: inline-block;
		padding: 0.38rem 0.72rem;
		border-radius: 999px;
		background: rgba(77, 163, 255, 0.14);
		color: var(--accent-2);
		font-size: 0.8rem;
		font-weight: 700;
	}

	.text-link {
		display: inline-block;
		margin-top: 1rem;
		color: var(--text);
		font-weight: 700;
		text-decoration: none;
	}

	.text-link:hover {
		color: var(--accent-2);
	}

	.lower-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1.2rem;
	}

	.info-panel {
		padding: 1.75rem;
		border-radius: 22px;
	}

	.info-panel ul {
		margin: 0.8rem 0 0;
		padding-left: 1.15rem;
	}

	.info-panel li + li {
		margin-top: 0.7rem;
	}

	@media (max-width: 980px) {
		.hero {
			padding: 2rem;
			min-height: 480px;
		}

		.about-preview {
			grid-template-columns: 1fr;
		}

		.card-grid,
		.lower-grid,
		.feature-grid {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 640px) {
		main {
			width: min(100% - 1rem, 1180px);
		}

		.hero {
			padding: 1.5rem;
			border-radius: 22px;
		}

		.hero h1 {
			max-width: 100%;
		}

		.about-preview,
		.info-panel,
		.content-card {
			padding: 1.2rem;
		}

		.about-image img {
			min-height: 280px;
		}
	}
</style>