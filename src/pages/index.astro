<style>
	:root {
		--bg: #0f1318;
		--bg-soft: #171c23;
		--panel: rgba(22, 28, 36, 0.82);
		--panel-border: rgba(255, 255, 255, 0.06);
		--text: #f3f1ec;
		--muted: #a9b0b8;
		--accent: #a97b5b;
		--accent-2: #d7b08f;
		--shadow: 0 20px 60px rgba(0, 0, 0, 0.38);
		--radius: 24px;
	}

	html,
	body {
		margin: 0;
		padding: 0;
		background:
			radial-gradient(circle at top left, rgba(169, 123, 91, 0.08), transparent 26%),
			radial-gradient(circle at top right, rgba(255, 255, 255, 0.025), transparent 18%),
			linear-gradient(180deg, #0d1116 0%, #13181f 100%);
		color: var(--text);
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI',
			sans-serif;
	}

	.page-shell {
		min-height: 100vh;
	}

	main {
		width: min(1180px, calc(100% - 2rem));
		margin: 0 auto;
		padding: 1.25rem 0 4rem;
	}

	.hero {
		position: relative;
		min-height: 560px;
		border-radius: 30px;
		overflow: hidden;
		display: flex;
		align-items: center;
		padding: 4rem;
		margin-bottom: 2rem;
		background:
			linear-gradient(
				90deg,
				rgba(11, 14, 18, 0.94) 0%,
				rgba(11, 14, 18, 0.82) 45%,
				rgba(11, 14, 18, 0.56) 100%
			);
		box-shadow: var(--shadow);
		border: 1px solid rgba(255, 255, 255, 0.05);
	}

	.hero-bg {
		position: absolute;
		inset: 0;
		background:
			linear-gradient(90deg, rgba(10, 13, 18, 0.74), rgba(10, 13, 18, 0.18)),
			url('/images/home/hero.jpg') center center / cover no-repeat;
		transform: scale(1.02);
		filter: saturate(0.82) brightness(0.72);
		background-blend-mode: multiply;
	}

	.hero-overlay {
		position: absolute;
		inset: 0;
		background:
			radial-gradient(circle at 72% 30%, rgba(169, 123, 91, 0.1), transparent 20%),
			radial-gradient(circle at 68% 58%, rgba(255, 255, 255, 0.04), transparent 18%);
	}

	.hero-inner {
		position: relative;
		z-index: 1;
		max-width: 640px;
	}

	.eyebrow,
	.section-label {
		margin: 0 0 0.85rem;
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--accent-2);
	}

	.hero h1 {
		margin: 0;
		font-size: clamp(2.5rem, 5vw, 4.5rem);
		line-height: 0.98;
		letter-spacing: -0.04em;
		max-width: 12ch;
		color: var(--text);
	}

	.lead {
		margin: 1.3rem 0 0;
		font-size: 1.08rem;
		line-height: 1.75;
		color: var(--muted);
		max-width: 58ch;
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.9rem;
		margin-top: 2rem;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.95rem 1.3rem;
		border-radius: 999px;
		text-decoration: none;
		font-weight: 700;
		transition:
			transform 0.2s ease,
			filter 0.2s ease,
			background 0.2s ease,
			border-color 0.2s ease;
	}

	.btn-primary {
		background: linear-gradient(135deg, #b68460, #8d6247);
		color: white;
		box-shadow: 0 10px 30px rgba(0, 0, 0, 0.26);
	}

	.btn-primary:hover {
		transform: translateY(-1px);
		filter: brightness(1.04);
	}

	.btn-secondary {
		background: rgba(255, 255, 255, 0.05);
		color: var(--text);
		border: 1px solid rgba(255, 255, 255, 0.08);
	}

	.btn-secondary:hover {
		background: rgba(255, 255, 255, 0.08);
	}

	.section-card,
	.info-panel,
	.content-card {
		background: var(--panel);
		backdrop-filter: blur(12px);
		border: 1px solid var(--panel-border);
		box-shadow: var(--shadow);
	}

	.about-preview {
		display: grid;
		grid-template-columns: 420px 1fr;
		gap: 2rem;
		padding: 2rem;
		border-radius: var(--radius);
		margin-bottom: 2rem;
	}

	.about-image img {
		width: 100%;
		height: 100%;
		min-height: 420px;
		object-fit: cover;
		border-radius: 20px;
		display: block;
		filter: saturate(0.92) contrast(1.02);
	}

	.about-copy h2,
	.content-section h2,
	.info-panel h2 {
		margin: 0 0 1rem;
		font-size: clamp(1.8rem, 3vw, 2.7rem);
		line-height: 1.08;
		letter-spacing: -0.03em;
		color: var(--text);
	}

	.about-copy p,
	.content-card p,
	.info-panel li {
		color: var(--muted);
		line-height: 1.7;
		font-size: 1rem;
	}

	.feature-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
		margin-top: 1.6rem;
	}

	.feature {
		padding: 1rem 1.1rem;
		border-radius: 18px;
		background: rgba(255, 255, 255, 0.025);
		border: 1px solid rgba(255, 255, 255, 0.06);
	}

	.feature h3 {
		margin: 0 0 0.45rem;
		font-size: 1rem;
		color: var(--text);
	}

	.feature p {
		margin: 0;
		font-size: 0.92rem;
		color: var(--muted);
	}

	.content-section {
		margin-bottom: 2rem;
	}

	.section-heading {
		display: flex;
		align-items: end;
		justify-content: space-between;
		margin-bottom: 1rem;
	}

	.card-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1.2rem;
	}

	.content-card {
		padding: 1.5rem;
		border-radius: 22px;
	}

	.content-card h3 {
		margin: 0.7rem 0 0.75rem;
		font-size: 1.35rem;
		color: var(--text);
	}

	.tag {
		display: inline-block;
		padding: 0.38rem 0.72rem;
		border-radius: 999px;
		background: rgba(169, 123, 91, 0.12);
		color: var(--accent-2);
		font-size: 0.8rem;
		font-weight: 700;
	}

	.text-link {
		display: inline-block;
		margin-top: 1rem;
		color: var(--text);
		font-weight: 700;
		text-decoration: none;
		transition: color 0.2s ease;
	}

	.text-link:hover {
		color: var(--accent-2);
	}

	.lower-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1.2rem;
	}

	.info-panel {
		padding: 1.75rem;
		border-radius: 22px;
	}

	.info-panel ul {
		margin: 0.8rem 0 0;
		padding-left: 1.15rem;
	}

	.info-panel li + li {
		margin-top: 0.7rem;
	}

	@media (max-width: 980px) {
		.hero {
			padding: 2rem;
			min-height: 480px;
		}

		.about-preview {
			grid-template-columns: 1fr;
		}

		.card-grid,
		.lower-grid,
		.feature-grid {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 640px) {
		main {
			width: min(100% - 1rem, 1180px);
		}

		.hero {
			padding: 1.5rem;
			border-radius: 22px;
		}

		.hero h1 {
			max-width: 100%;
		}

		.about-preview,
		.info-panel,
		.content-card {
			padding: 1.2rem;
		}

		.about-image img {
			min-height: 280px;
		}
	}
</style>